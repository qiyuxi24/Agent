{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/src/nicegui/static/tauri/tauri.conf.json",
  "productName": "Agent Desktop",
  "version": "0.1.0",
  "identifier": "com.agent.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Desktop",
        "width": 960,
        "height": 680,
        "minWidth": 680,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../mcp-servers/**": "mcp-servers/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
